# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# =============================================================================
# Règles Globales
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# =============================================================================
# Shell Scripts
# =============================================================================
[*.{sh,bash}]
indent_size = 4
trim_trailing_whitespace = true

# =============================================================================
# Python
# =============================================================================
[*.py]
indent_size = 4
max_line_length = 100

# =============================================================================
# Markdown
# =============================================================================
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# =============================================================================
# YAML
# =============================================================================
[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# JSON
# =============================================================================
[*.json]
indent_size = 2

# =============================================================================
# Scala
# =============================================================================
[*.scala]
indent_size = 4

# =============================================================================
# Java
# =============================================================================
[*.java]
indent_size = 4

# =============================================================================
# Configuration Files
# =============================================================================
[*.{conf,config}]
indent_size = 2

# =============================================================================
# SQL / CQL
# =============================================================================
[*.{sql,cql}]
indent_size = 2

# =============================================================================
# Makefile
# =============================================================================
[Makefile]
indent_style = tab

# =============================================================================
# Git
# =============================================================================
[.gitignore]
indent_size = 2

