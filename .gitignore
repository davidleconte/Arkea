# =============================================================================
# .gitignore pour POC Migration HBase → HCD
# =============================================================================
# Date : 2025-12-01
# =============================================================================

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
*.log.*

# =============================================================================
# Données
# =============================================================================
# Répertoires de données générées
data/
hcd-data/
**/data/
**/data/**

# Fichiers de données générés par les scripts
*.parquet
*.parquet/
**/*.parquet
**/*.parquet/
*.csv
*.json
*.orc
*.orc/
**/*.orc
**/*.orc/
*.avro
*.avro/
**/*.avro
**/*.avro/

# Répertoires Parquet (avec _SUCCESS et part-*.parquet)
**/_SUCCESS
**/part-*.parquet
**/part-*.snappy.parquet

# Répertoires de données spécifiques aux POCs
poc-design/*/data/
poc-design/*/data/**
poc-design/*/data/parquet/
poc-design/*/data/json/
poc-design/*/data/csv/
poc-design/*/data/temp/
poc-design/*/data/tmp/
poc-design/*/data/export/
poc-design/*/data/checkpoints/
poc-design/*/data/checkpoints/**

# Exports batch
**/export/
**/exports/
**/export/**
**/exports/**

# Checkpoints (Kafka, Spark)
**/checkpoints/
**/checkpoints/**
**/checkpoint/
**/checkpoint/**
*.checkpoint
*.checkpoint/

# Fichiers temporaires
**/temp/
**/temp/**
**/tmp/
**/tmp/**
*.tmp
*.temp

# Archives de données
*.zip
*.tar.gz
*.tgz

# =============================================================================
# Binaires et Logiciels
# =============================================================================
binaire/
software/
*.tar.gz
*.tgz
*.jar

# =============================================================================
# Fichiers Temporaires
# =============================================================================
*.tmp
*.bak
*.swp
*.swo
*~

# =============================================================================
