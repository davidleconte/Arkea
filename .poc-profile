# =============================================================================
# Configuration des Variables d'Environnement pour le POC HBase → HCD
# =============================================================================
# Date : 2025-12-01 (Mise à jour pour utiliser .poc-config.sh)
# Usage : source .poc-profile
# =============================================================================
#
# NOTE : Ce fichier charge maintenant .poc-config.sh qui contient la configuration
#        centralisée portable. Les chemins hardcodés ont été remplacés par une
#        détection automatique multi-OS.
# =============================================================================

# Charger la configuration centralisée (.poc-config.sh)
# Ce fichier détecte automatiquement ARKEA_HOME et configure tous les chemins
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-${0}}")" && pwd)"
if [ -f "${SCRIPT_DIR}/.poc-config.sh" ]; then
    # shellcheck source=/dev/null
    source "${SCRIPT_DIR}/.poc-config.sh"
    export POC_HOME="${ARKEA_HOME}"
else
    # Fallback portable si .poc-config.sh n'existe pas (compatibilité ascendante)
    # Détection automatique du répertoire du projet
    if [ -z "${ARKEA_HOME:-}" ]; then
        # Ce fichier est à la racine, donc ARKEA_HOME = répertoire de ce fichier
        ARKEA_HOME="$(cd "$(dirname "${BASH_SOURCE[0]:-${0}}")" && pwd)"
        export ARKEA_HOME
    fi
    export POC_HOME="${ARKEA_HOME}"
fi

# =============================================================================
# Java, HCD, Spark, Kafka Configuration
# =============================================================================
# NOTE : Ces configurations sont maintenant gérées par .poc-config.sh
#        Les variables suivantes sont définies pour compatibilité ascendante
#        mais .poc-config.sh a déjà tout configuré avec détection automatique.
# =============================================================================

# Les variables suivantes sont déjà définies par .poc-config.sh :
# - JAVA_HOME, JAVA11_HOME, JAVA17_HOME
# - HCD_HOME, HCD_DIR, CASSANDRA_HOME
# - SPARK_HOME, SPARK_VERSION, SPARK_CONF_DIR
# - KAFKA_HOME, KAFKA_VERSION
# - ZOOKEEPER_HOME
# - HCD_HOST, HCD_PORT
# - Et toutes les autres variables de configuration

# Alias pour compatibilité (HCD_HOME peut être défini comme HCD_DIR)
export HCD_HOME="${HCD_HOME:-${HCD_DIR}}"

# Kafka config (si non défini par .poc-config.sh)
export KAFKA_CONFIG="${KAFKA_CONFIG:-${KAFKA_HOME}/.bottle/etc/kafka}"
export KAFKA_LOG_DIR="${KAFKA_LOG_DIR:-${KAFKA_HOME}/libexec/logs}"

# Zookeeper config (si non défini par .poc-config.sh)
export ZOOKEEPER_CONFIG="${ZOOKEEPER_CONFIG:-${ZOOKEEPER_HOME}/libexec/conf}"

# =============================================================================
# PATH, Python, et autres configurations
# =============================================================================
# NOTE : Ces configurations sont maintenant gérées par .poc-config.sh
#        Les variables suivantes sont définies pour compatibilité ascendante.
# =============================================================================

# PATH est déjà configuré par .poc-config.sh
# Python est déjà configuré par .poc-config.sh
# Spark options sont déjà configurées par .poc-config.sh
# HCD/Cassandra config est déjà configurée par .poc-config.sh
# Kafka config est déjà configurée par .poc-config.sh
# Répertoires de données sont déjà configurés par .poc-config.sh
# Keyspace et tables sont déjà configurés par .poc-config.sh

# Alias cqlsh (si Python 3.11 disponible)
if command -v python3.11 &> /dev/null && [ -n "${HCD_HOME:-}" ]; then
    alias cqlsh="python3.11 ${HCD_HOME}/resources/cassandra/bin/cqlsh.py"
fi

# =============================================================================
# Fonctions Utilitaires
# =============================================================================

# Fonction pour vérifier que toutes les variables sont définies
check_poc_env() {
    echo "=== Vérification des Variables d'Environnement POC ==="
    echo ""

    local errors=0

    # Vérifier JAVA_HOME
    if [ -z "$JAVA_HOME" ] || [ ! -d "$JAVA_HOME" ]; then
        echo "❌ JAVA_HOME non défini ou invalide"
        errors=$((errors + 1))
    else
        echo "✅ JAVA_HOME: $JAVA_HOME"
        java -version 2>&1 | head -1
    fi

    # Vérifier HCD_HOME
    if [ -z "$HCD_HOME" ] || [ ! -d "$HCD_HOME" ]; then
        echo "❌ HCD_HOME non défini ou invalide: $HCD_HOME"
        errors=$((errors + 1))
    else
        echo "✅ HCD_HOME: $HCD_HOME"
    fi

    # Vérifier SPARK_HOME
    if [ -z "$SPARK_HOME" ] || [ ! -d "$SPARK_HOME" ]; then
        echo "❌ SPARK_HOME non défini ou invalide: $SPARK_HOME"
        errors=$((errors + 1))
    else
        echo "✅ SPARK_HOME: $SPARK_HOME"
    fi

    # Vérifier KAFKA_HOME
    if [ -z "$KAFKA_HOME" ] || [ ! -d "$KAFKA_HOME" ]; then
        echo "❌ KAFKA_HOME non défini ou invalide: $KAFKA_HOME"
        errors=$((errors + 1))
    else
        echo "✅ KAFKA_HOME: $KAFKA_HOME"
    fi

    echo ""
    if [ $errors -eq 0 ]; then
        echo "✅ Toutes les variables sont correctement configurées !"
    else
        echo "❌ $errors erreur(s) détectée(s)"
    fi
}

# Fonction pour démarrer HCD
start_hcd() {
    cd "$HCD_HOME"
    if [ "$1" = "background" ] || [ "$1" = "bg" ]; then
        nohup bin/hcd cassandra > logs/hcd.log 2>&1 &
        echo "✅ HCD démarré en arrière-plan (PID: $!)"
        echo "📋 Logs: $HCD_HOME/logs/hcd.log"
    else
        bin/hcd cassandra
    fi
}

# Fonction pour démarrer Kafka
start_kafka() {
    cd "$KAFKA_HOME"
    if [ "$1" = "background" ] || [ "$1" = "bg" ]; then
        export JAVA_HOME="$JAVA17_HOME"
        nohup libexec/bin/kafka-server-start.sh .bottle/etc/kafka/server.properties > libexec/logs/kafka.log 2>&1 &
        echo "✅ Kafka démarré en arrière-plan (PID: $!)"
        echo "📋 Logs: $KAFKA_HOME/libexec/logs/kafka.log"
        export JAVA_HOME="$JAVA11_HOME"  # Remettre Java 11 par défaut
    else
        export JAVA_HOME="$JAVA17_HOME"
        libexec/bin/kafka-server-start.sh .bottle/etc/kafka/server.properties
    fi
}

# Fonction pour lancer Spark Shell avec les packages nécessaires
spark_shell_poc() {
    cd "$POC_HOME"
    "$SPARK_HOME/bin/spark-shell" \
        --packages "$SPARK_PACKAGES" \
        $SPARK_OPTS \
        "$@"
}

# =============================================================================
# Affichage de la Configuration
# =============================================================================

if [ -n "$PS1" ]; then
    echo "✅ Variables d'environnement POC chargées"
    echo "   POC_HOME: $POC_HOME"
    echo "   JAVA_HOME: $JAVA_HOME"
    echo "   SPARK_HOME: $SPARK_HOME"
    echo "   HCD_HOME: $HCD_HOME"
    echo "   KAFKA_HOME: $KAFKA_HOME"
    echo ""
    echo "💡 Commandes utiles:"
    echo "   check_poc_env          - Vérifier la configuration"
    echo "   start_hcd [background] - Démarrer HCD"
    echo "   start_kafka [background] - Démarrer Kafka"
    echo "   spark_shell_poc        - Lancer Spark Shell avec packages POC"
fi


